# Alpaca API credentials (paper keys work fine — this script only reads data)
# Add more pairs to distribute load; any pair present in the environment is used.
ALPACA_API_KEY=your_api_key_here
ALPACA_API_SECRET=your_api_secret_here
ALPACA_API_KEY_QICHAO=your_second_api_key_here
ALPACA_API_SECRET_QICHAO=your_second_api_secret_here

# Discord webhook URL (Server Settings → Integrations → Webhooks → Copy Webhook URL)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy
